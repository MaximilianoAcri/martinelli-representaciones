# Despliegue recomendado: Vercel (conectá el repo y cargá estas variables en Project → Settings → Environment Variables).
#
# Cliente Firebase (públicas en el bundle; igual conviene no hardcodearlas)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Servidor (API routes): JSON del service account en UNA sola línea (sin saltos).
# En producción usá el secreto del hosting (Vercel, etc.), no un archivo en el repo.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Opcional: ruta absoluta a un JSON de cuenta de servicio (local o CI)
# GOOGLE_APPLICATION_CREDENTIALS=
