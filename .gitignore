# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# credentials (sensitive)
credentials/

# hojas de cálculo / datos locales
*.xlsx
*.xls

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# System Zero (no needed in repo)
.sz/
.sz.yaml
install-sz.sh

# Virtual environment
.venv/

# Firebase (local config)
firebase-debug.log*
firestore-debug.log*
firebase-debug.log
firestore-debug.log

# Proposals/Memoria (no subir a GitHub)
docs/
issue-*.md
human-approval-system.md
