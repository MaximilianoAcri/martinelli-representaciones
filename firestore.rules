rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colección contactos - cualquiera puede escribir, solo leer desde el cliente
    match /contactos/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Colección newsletter - cualquiera puede escribir, solo leer desde el cliente
    match /newsletter/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Colección cotizaciones - solo lectura pública
    match /cotizaciones/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users del dashboard (si los hay)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Perfil app (AuthContext / mi-cuenta) — mismo uid que Firebase Auth
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}